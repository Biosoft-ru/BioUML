{
    id: "git_clone",
    label: "Git clone",
    icon: "icons/Git.png",
    visible: "function(completePath)
    {
        var path = getElementPath(completePath);
        var name = getElementName(completePath);
        if(!path || !name) return -1;
        var edc = getDataCollection(completePath);
        
        var parent = getDataCollection(path);
        var type = parent.getChildClass(name);
        if( edc && instanceOf( type,'ru.biosoft.access.Repository' ) && edc.isGitEnabled() ) 
        {
            return true;
        }
        return -1;
    }",
    action: "function(path)
    {
        loadBioUMLModules(['git'], function()
        {
        }, function()
        {
            gitClone(path);
        });
    }"
}